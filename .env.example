# Kubernetes AI/ML Lab Environment Variables
# Copy this file to .env and fill in your actual values

# Tailscale Configuration
# Get your auth key from: https://login.tailscale.com/admin/settings/keys
# TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx

# K3s Configuration (auto-detected if running locally)
# K3S_URL=https://100.x.y.z:6443
# K3S_TOKEN=K10xxxxxxxxxx::server:xxxxxxxxxx

# Vast.ai Configuration
# MAX_DPH=0.50
# MIN_COMPUTE_CAP=700
# SEARCH_LIMIT=10
